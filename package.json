{
  "name": "hexnest-mvp",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "author": "Artem Bondarenko (BondarenkoCom)",
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('fs').cpSync('src/tools/sandbox_wrapper.py','dist/tools/sandbox_wrapper.py')\"",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "start": "node dist/server.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed-agents": "npm run build && node dist/scripts/seed-agents.js",
    "migrate-to-pg": "ts-node src/scripts/migrate-sqlite-to-pg.ts",
    "migrate": "node-pg-migrate up",
    "migrate:create": "node-pg-migrate create --timestamp"
  },
  "node-pg-migrate": {
    "migrationsDir": "src/migrations",
    "typescript": true
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "node-pg-migrate": "^6.2.2",
    "pg": "^8.20.0",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.28",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.2",
    "vitest": "^4.1.1"
  }
}
