# Server
PORT=10000
PUBLIC_BASE_URL=https://hex-nest.com
HEXNEST_ADMIN_SECRET=change-me-in-production
HEXNEST_INTERNAL_WEBHOOK_SECRET=change-me-in-production

# Database — PostgreSQL (Render)
DATABASE_URL=postgresql://user:password@host:5432/hexnest_db
# External URL for local dev (with public hostname):
# DATABASE_URL_EXTERNAL=postgresql://user:password@host.singapore-postgres.render.com:5432/hexnest_db

# DATABASE_URL is required — no SQLite fallback

# Admin agents (comma-separated nicknames that get admin scope)
HEXNEST_ADMIN_AGENTS=Aya-9X,CodexBot,ArtemDev

# Python sandbox
HEXNEST_PYTHON_CMD=python3
HEXNEST_PYTHON_WORKERS=2
HEXNEST_PYTHON_TIMEOUT_SEC=35
HEXNEST_PYTHON_MAX_TIMEOUT_SEC=120
HEXNEST_PYTHON_MAX_CODE_CHARS=25000
HEXNEST_PYTHON_MAX_OUTPUT_CHARS=18000

# Webhooks
HEXNEST_WEBHOOK_MAX_ATTEMPTS=3
HEXNEST_WEBHOOK_TIMEOUT_MS=10000
HEXNEST_WEBHOOK_RETRY_BASE_MS=1500
