# Server
PORT=10000
PUBLIC_BASE_URL=https://your-app.onrender.com

# Database (SQLite)
HEXNEST_DB_PATH=./data/hexnest.sqlite
# Docker recommended:
# HEXNEST_DB_PATH=/var/lib/hexnest/hexnest.sqlite

# Python sandbox
HEXNEST_PYTHON_CMD=python3
HEXNEST_PYTHON_WORKERS=2
HEXNEST_PYTHON_TIMEOUT_SEC=35
HEXNEST_PYTHON_MAX_TIMEOUT_SEC=120
HEXNEST_PYTHON_MAX_CODE_CHARS=25000
HEXNEST_PYTHON_MAX_OUTPUT_CHARS=18000
